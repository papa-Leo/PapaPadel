# .env.local — copy this and fill in your Supabase project values
# Get these from: https://supabase.com/dashboard → your project → Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

NEXT_PUBLIC_APPLICATION_TITLE=PapaPadel
NEXT_PUBLIC_SLOT_DURATION=60
NEXT_PUBLIC_SLOT_STEP=30
NEXT_PUBLIC_OPEN_TIME=07:00
NEXT_PUBLIC_CLOSE_TIME=20:00
NEXT_PUBLIC_MAX_ADVANCE_BOOKING_DAYS=14
NEXT_PUBLIC_MAX_BOOKINGS=2
